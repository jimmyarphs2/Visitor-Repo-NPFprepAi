{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the candidate.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "User profile picture" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation time" }
      },
      "required": ["uid", "email"]
    },
    "Event": {
      "title": "App Event",
      "description": "Logs for tracking user interactions.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User UID (if authenticated)" },
        "type": { "type": "string", "enum": ["click", "scroll", "signup", "whatsapp_join"], "description": "Type of event" },
        "data": { "type": "object", "description": "Additional event metadata" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the event occurred" }
      },
      "required": ["type", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Interaction logs."
    }
  }
}
